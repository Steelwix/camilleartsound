<turbo-stream action="replace" target="dashboard">
    <template>
        <div id="dashboard">
            {% set total = 6 %}
            {% set perRow = projectPerRow %}
            {% for i in 1..total %}
                {% if (i - 1) % perRow == 0 %}
                    <div class="row mb-4">
                {% endif %}

                {% if demos[i] is defined and demos[i] is not null %}

                <div class="col-md-12 col-lg-{{ 12 / perRow }} mb-5">
                    <div class="card border-light rounded overflow-hidden shadow-sm">
                        <div class="card-body p-2 bg-dark d-flex justify-content-center align-items-center" style="min-height: 200px;">
                            <div class="lock-video-format">
                                {% set ext = demos[i].media.name|split('.')|last %}
                                <video class="w-100 rounded" controls playsinline webkit-playsinline preload="metadata"
                                        {% if demos[i].thumbnail is not null %} poster="{{ asset('upload/thumbnail/' ~ demos[i].thumbnail.name) }}"{% endif %}>
                                <source src="{{ asset('upload/demo/' ~ demos[i].media.name) }}" type="video/{{ ext }}">
                                    This video seems unsupported by your browser
                                </video>
                            </div>



                        </div>
                    </div>
                    <a href="{{ path('app_settings_demo', {'id': demos[i].id}) }}"
                       class="btn btn-primary w-100 mb-2" data-turbo="onClick">
                        Modifier le projet {{ demos[i].id }}
                    </a>
                </div>
                {% else %}
                    <a href="{{ path('app_settings_demo') }}"
                       class="btn btn-primary w-100 mb-2" data-turbo="onClick">
                        Ajouter un projet
                    </a>
                {% endif %}
                {% if i % perRow == 0 or i == total %}
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </template>
</turbo-stream>