{% extends 'base.html.twig' %}

{% block body %}
    <div id="homepage">
    <div id="header">
        {% include "_partials/_light_nav.html.twig" %}

        <div id="home" class="container-fluid hero-section" style="position: relative; height: 100vh; overflow: hidden;">
            {% set ext = headerMedia.name|split('.')|last|lower %}

            {% if ext in ['jpg', 'jpeg', 'png', 'gif'] %}
                <div style="
                        background-image: url('{{ asset('upload/header/' ~ headerMedia) }}');
                        background-size: cover; background-position: center;
                        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
                        z-index: -1;">
                </div>
            {% elseif ext in ['mp4', 'webm'] %}
                <video preload="metadata" autoplay loop muted playsinline style="
            width: 100%; height: 100%; object-fit: cover;
            position: absolute; top: 0; left: 0;
            z-index: -1;">
                    <source src="{{ asset('upload/header/' ~ headerMedia.name) }}" type="video/{{ ext }}">
                    Votre navigateur ne supporte pas la vidéo.
                </video>
            {% else %}
                <p>Format non supporté</p>
            {% endif %}



                <div class="text-center row">
                    <h1 style="" class="header-title text-white col-12 breathing">Camille SABY</h1>
                    <h4 class="header-subtitle text-white col-12 breathing">▲ Sound Designer // Technical SD ▼</h4>

                    <div class="col-12 breathing">
                        <div class="empty-10"></div>
                        <a href="{{ path('app_home_venture') }}" class="glitch-btn text-white mx-5" data-text="Projects">Projects</a>
                        <a href="#work" class="glitch-btn text-white mx-5" data-text="Demo">Demo</a>
                    </div>

                </div>

            </div>
        </div>
        <div class="section-divider"></div>
        <div style="min-height: 100vh" id="work" class="container">
            <div class="row">
                <div class="col-12 col-md-6 mx-auto">
                    <div class="cp-block">
                        <h5 class="cp-title">//_Showreel 2025_//</h5>

                        <div class="cp-frame">
                            <video class="w-100 cp-video" controls preload="metadata">
                                <source src="{{ asset('upload/showreel/' ~ showreel.name) }}" type="video/{{ ext }}">
                            </video>
                        </div>
                    </div>
                </div>


                <div class="col-12 mt-5 mb-5">
                    <h3 class="text-center breathing">Selected Work</h3>
                </div>


                {% set total = 6 %}
                {% set perRow = projectPerRow %}
                {% for i in 1..total %}
                    {% if (i - 1) % perRow == 0 %}
                        <div class="row mb-4">
                    {% endif %}

                    <div class="col-md-12 col-lg-{{ 12 / perRow }} mb-5">
                        <div class="ui-frame">
                            <div class="ui-frame-body" style="min-height: 200px; --i: {{ i }}">
                                <p style="font-size: 0.5rem;color:var(--color-primary)" class="text-center">//_{{ demos[i].media.name }}_//</p>
                                {% if demos[i] is not null %}
                                    {% set ext = demos[i].media.name|split('.')|last|lower %}
                                <div class="lock-video-format">
                                    <video class="w-100" controls playsinline webkit-playsinline preload="metadata"
                                    {% if demos[i].thumbnail is not null %} poster="{{ asset('upload/thumbnail/' ~ demos[i].thumbnail.name) }}"{% endif %}>
                                        <source src="{{ asset('upload/demo/' ~ demos[i].media.name) }}" type="video/{{ ext }}">
                                        This video seems unsupported by your browser
                                    </video>
                                </div>
                                {% else %}
                                    <p class="text-light text-center m-0">Aucun projet</p>
                                {% endif %}
                            </div>
                        </div>

                    </div>

                    {% if i % perRow == 0 or i == total %}
                        </div>
                    {% endif %}
                {% endfor %}

            </div>
        </div>

        <div class="section-divider"></div>



        <div id="canvas" class="d-none d-xl-block">
            <div id="nodeA" class="node fixed" style="max-width: 350px;">
                <img class="img-fluid mx-auto rounded-circle"
                     src="{{ asset('upload/bio/' ~ bioImage.name) }}"
                     alt="Photo de profil"
                     style="width: 100%; aspect-ratio: 1/1; object-fit: cover;">
            </div>

            <div id="nodeB" class="node cp-block" style="max-width: 40vh;">
                <h5 class="cp-title">{{ bioTexts.title1 }}</h5>
                <p id="anchor" class="cp-video cp-frame">{{ bioTexts.text1|raw }}</p>
            </div>

            <div id="nodeC" class="node cp-block" style="max-width: 40vh;">
                <h5 class="cp-title">{{ bioTexts.title2 }}</h5>
                <p id="anchorC" class="cp-video cp-frame">
                    {{ bioTexts.text2|raw }}
                </p>
            </div>

            <div id="nodeD" class="node cp-block" style="max-width: 40vh;">
                <h5 class="cp-title">{{ bioTexts.title3 }}</h5>
                <p id="anchorD" class="cp-video cp-frame">
                    {{ bioTexts.text3|raw }}
                </p>
            </div>
            <svg id="links"
                 style="
        position:absolute;
        inset:0;
        width:100%;
        height:100%;
        pointer-events:none;
        z-index:15;
     ">

                <defs>
                    <filter id="neon-glow" x="-50%" y="-50%" width="200%" height="200%">
                        <feGaussianBlur stdDeviation="6" result="blur1"/>
                        <feGaussianBlur stdDeviation="12" result="blur2"/>
                        <feMerge>
                            <feMergeNode in="blur2"/>
                            <feMergeNode in="blur1"/>
                            <feMergeNode in="SourceGraphic"/>
                        </feMerge>
                    </filter>
                </defs>

                <line id="linkB" stroke="#fffc00" stroke-width="2" filter="url(#neon-glow)" />
                <line id="linkC" stroke="#fffc00" stroke-width="2" filter="url(#neon-glow)" />
                <line id="linkD" stroke="#fffc00" stroke-width="2" filter="url(#neon-glow)" />

            </svg>
        </div>

        <div class="d-xl-none">
            <div class="row justify-content-center">
                <div class="col-6" style="max-width: 350px;">
                    <div class="ratio ratio-1x1 rounded-circle overflow-hidden">
                        <img class="img-fluid w-100 h-100"
                             src="{{ asset('upload/bio/' ~ bioImage.name) }}"
                             alt="Photo de profil"
                             style="object-fit: cover;">
                    </div>
                </div>

                <div class="col-6 mt-3">
                    <div id="nodeB2" class="node cp-block">
                        <h5 class="cp-title">{{ bioTexts.title1 }}</h5>
                        <p id="anchor" class="cp-video cp-frame">{{ bioTexts.text1|raw }}</p>
                    </div>

                    <div id="nodeC2" class="node cp-block">
                        <h5 class="cp-title">{{ bioTexts.title2 }}</h5>
                        <p id="anchor" class="cp-video cp-frame">{{ bioTexts.text2|raw }}</p>
                    </div>

                    <div id="nodeD2" class="node cp-block">
                        <h5 class="cp-title">{{ bioTexts.title3 }}</h5>
                        <p id="anchor" class="cp-video cp-frame">{{ bioTexts.text3|raw }}</p>
                    </div>
                </div>

            </div>
        </div>


        <div class="section-divider"></div>

        <div style="margin-bottom: 35vh" class="container">
            <div class="row">
                <div class="col-12 mt-5 mb-5 text-center">
                    <h3 class="breathing">CONTACT ME</h3>
                    {% for contact in bioContacts %}
                        <p>{{ contact.text }}</p>
                     {% endfor %}
                    <a class="mailto" style="color:#ff252b ;text-decoration: none" href="mailto:{{ bioMail }}">{{ bioMail }}</a>
                </div>
                <div class="col-12 text-center social-links">
                    {% for social in bioSocials %}
                        <a href="{{ social.link }}" class="social-icon">
                            {% if social.network %}
                                <i class="bi bi-{{ social.network }}"></i>
                            {% elseif 'itch.io' in social.link %}
                                {% include 'icons/itchio.svg' %}
                            {% else %}
                                <i class="bi bi-globe"></i>
                            {% endif %}
                        </a>
                    {% endfor %}

{#                    <i class=" bi bi-github fs-2"></i>#}
{#                    <i class=" bi bi-linkedin fs-2"></i>#}
{#                    <i class=" bi bi-instagram fs-2"></i>#}
{#                    <i class=" bi bi-facebook fs-2"></i>#}
{#                    <i class=" bi bi-twitter fs-2"></i>#}
{#                    <i class=" bi bi-whatsapp fs-2"></i>#}
{#                    <i class=" bi bi-discord fs-2"></i>#}
{#                    <i class=" bi bi-youtube fs-2"></i>#}
{#                    <i class=" bi bi-twitch fs-2"></i>#}
{#                    <i class=" bi bi-pinterest fs-2"></i>#}
{#                    <i class=" bi bi-spotify fs-2"></i>#}
{#                    <i class=" bi bi-snapchat fs-2"></i>#}
                </div>
            </div>
        </div>
<div class="empty-10"></div>
    </div>

    <script>
        (() => {

            /* ===============================
               RÉCUPÉRATION DES ÉLÉMENTS DOM
            =============================== */

            const canvas = document.getElementById("canvas");
            if (!canvas) return; // sécurité si jamais le canvas n'existe pas

            const nodeA = document.getElementById("nodeA"); // photo centrale
            const nodeB = document.getElementById("nodeB");
            const nodeC = document.getElementById("nodeC");
            const nodeD = document.getElementById("nodeD");

            const anchorB = document.getElementById("anchor");   // point d’attache B
            const anchorC = document.getElementById("anchorC");  // point d’attache C
            const anchorD = document.getElementById("anchorD");  // point d’attache D

            const linkB = document.getElementById("linkB");
            const linkC = document.getElementById("linkC");
            const linkD = document.getElementById("linkD");

            const MIN_DISTANCE = 150; // distance minimale entre centre photo et nodes

            /* ===============================
               INTERSECTION OBSERVER (animation)
            =============================== */

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        setTimeout(() => {
                            entry.target.classList.add("is-visible"); // déclenche animation
                            observer.unobserve(entry.target); // une seule fois
                        }, 300);
                    }
                });
            }, { threshold: 0.3 });

            document.querySelectorAll(".ui-frame").forEach(el => {
                observer.observe(el);
            });

            /* ===============================
               SYSTÈME DE DRAG (stable)
            =============================== */

            let dragging = null;      // élément actuellement déplacé
            let startX = 0;           // position souris au moment du clic
            let startY = 0;
            let originLeft = 0;       // position initiale du node
            let originTop = 0;

            /* ----- DÉBUT DU DRAG ----- */
            document.addEventListener("mousedown", (e) => {

                // Vérifie si on clique sur un node
                const target = e.target.closest("#nodeB, #nodeC, #nodeD");
                if (!target) return;

                dragging = target;

                // On mémorise la position initiale de la souris
                startX = e.clientX;
                startY = e.clientY;

                // On mémorise la position initiale du node
                originLeft = dragging.offsetLeft;
                originTop  = dragging.offsetTop;
            });

            /* ----- MOUVEMENT ----- */
            document.addEventListener("mousemove", (e) => {
                if (!dragging) return;

                const rectCanvas = canvas.getBoundingClientRect();
                const rectA = nodeA.getBoundingClientRect();

                // Calcul du déplacement réel de la souris
                const dx = e.clientX - startX;
                const dy = e.clientY - startY;

                // Nouvelle position = position initiale + déplacement souris
                let newLeft = originLeft + dx;
                let newTop  = originTop  + dy;

                // Limite dans le canvas
                const maxX = rectCanvas.width  - dragging.offsetWidth;
                const maxY = rectCanvas.height - dragging.offsetHeight;

                console.log("newTop = " + newTop);
                newLeft = Math.min(Math.max(newLeft, 0), maxX);
                newTop  = Math.min(Math.max(newTop, 0), maxY);

                /* --- DISTANCE MINIMALE PAR RAPPORT À LA PHOTO --- */

                // const ax = rectA.left + rectA.width / 2;
                // const ay = rectA.top  + rectA.height / 2;
                //
                // const bx = newLeft + rectCanvas.left + dragging.offsetWidth / 2;
                // const by = newTop  + rectCanvas.top  + dragging.offsetHeight / 2;
                //
                // const dist = Math.hypot(bx - ax, by - ay);
                // if (dist < MIN_DISTANCE) return;

                // Application position
                dragging.style.left = newLeft + "px";
                dragging.style.top  = newTop  + "px";

                updateAllLines();
            });

            /* ----- FIN DU DRAG ----- */
            document.addEventListener("mouseup", () => {
                dragging = null;
            });

            /* ===============================
               SYSTÈME DE LIGNES (photo → nodes)
            =============================== */

            function updateLine(anchor, line) {

                if (!anchor || !line) return;

                const rectA = nodeA.getBoundingClientRect();
                const rectB = anchor.getBoundingClientRect();
                const rectC = canvas.getBoundingClientRect();

                // Centre photo
                const ax = rectA.left + rectA.width  / 2 - rectC.left;
                const ay = rectA.top  + rectA.height / 2 - rectC.top;

                // Centre du bloc cible
                const bx = rectB.left + rectB.width  / 2 - rectC.left;
                const by = rectB.top  + rectB.height / 2 - rectC.top;

                const dx = bx - ax;
                const dy = by - ay;

                const len = Math.hypot(dx, dy);
                if (!len) return;

                const ux = dx / len;
                const uy = dy / len;

                const rA = rectA.width / 2;

                // Point de départ = bord du cercle
                const startX = ax + ux * rA;
                const startY = ay + uy * rA;

                // Intersection rectangle
                const halfW = rectB.width  / 2;
                const halfH = rectB.height / 2;

                const tx = Math.abs(ux) > 0.0001 ? halfW / Math.abs(ux) : Infinity;
                const ty = Math.abs(uy) > 0.0001 ? halfH / Math.abs(uy) : Infinity;

                const t = Math.min(tx, ty);

                const endX = bx - ux * t;
                const endY = by - uy * t;

                line.setAttribute("x1", startX);
                line.setAttribute("y1", startY);
                line.setAttribute("x2", endX);
                line.setAttribute("y2", endY);
            }

            function updateAllLines() {
                updateLine(anchorB, linkB);
                updateLine(anchorC, linkC);
                updateLine(anchorD, linkD);
            }

            /* ===============================
               POSITION INITIALE DES BLOCS
            =============================== */

            function setInitialPositions() {

                const rectCanvas = canvas.getBoundingClientRect();

                const centerX = rectCanvas.width / 2;
                const centerY = rectCanvas.height / 2;
                const sideOffsetY = -40;

                // Photo centrée
                nodeA.style.left = centerX - nodeA.offsetWidth / 2 + 10 + "px";
                nodeA.style.top  = centerY - nodeA.offsetHeight / 2 + "px";

                // Bloc du haut
                nodeB.style.left = centerX - nodeB.offsetWidth / 2 + "px";
                nodeB.style.top  = centerY - nodeA.offsetHeight / 2 - nodeB.offsetHeight - 80 + "px";

                // Bloc gauche
                nodeC.style.left = centerX - nodeA.offsetWidth / 2 - nodeC.offsetWidth - 120 + "px";
                nodeC.style.top  = centerY + sideOffsetY + "px";

                // Bloc droite
                nodeD.style.left = centerX + nodeA.offsetWidth / 2 + 120 + "px";
                nodeD.style.top  = centerY + sideOffsetY + "px";
            }

            /* ===============================
               INIT + RESIZE
            =============================== */

            window.addEventListener("load", () => {
                setInitialPositions();
                updateAllLines();
            });

            window.addEventListener("resize", () => {
                setInitialPositions();
                updateAllLines();
            });

        })();
    </script>

        {% endblock %}
